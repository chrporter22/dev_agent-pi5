# ==============================
# OpenClaw VDB Configuration
# ==============================

# ------------------------------
# SERVICE CONFIG
# ------------------------------
VDB_SERVICE_NAME=openclaw-vdb
VDB_PORT=8081

# internal-only (Docker network)
VDB_HOST=0.0.0.0

# ------------------------------
# STORAGE CONFIG
# ------------------------------
VDB_NVME_PATH=/data
VDB_SQLITE_DB=/data/db.sqlite
VDB_FAISS_INDEX=/data/index.bin

# ------------------------------
# SEARCH CONFIG
# ------------------------------
VDB_TOP_K=5
VDB_DISTANCE_METRIC=cosine

# ------------------------------
# MEMORY / PERFORMANCE
# ------------------------------
VDB_MEMORY_LIMIT=1GB
VDB_BATCH_SIZE=32
VDB_MAX_CONCURRENT_REQUESTS=10

# ------------------------------
# EMBEDDING CONFIG
# ------------------------------
VDB_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VDB_EMBEDDING_DIM=384
VDB_EMBEDDING_BACKEND=local

# options:
# local | openai | external_api

# ------------------------------
# FAISS CONFIG
# ------------------------------
VDB_FAISS_INDEX_TYPE=IndexFlatIP
VDB_FAISS_REBUILD_ON_START=false

# ------------------------------
# ML INTEGRATION
# ------------------------------
VDB_ENABLE_ML_SYNC=true
VDB_ML_SERVICE=http://openclaw-ml:8080
VDB_ML_SYNC_INTERVAL=60

# ------------------------------
# REDIS INTEGRATION (for cache bridge)
# ------------------------------
VDB_REDIS_ENABLED=true
VDB_REDIS_HOST=redis
VDB_REDIS_PORT=6379
VDB_REDIS_PREFIX=cache:vdb

# ------------------------------
# OBSERVABILITY
# ------------------------------
VDB_LOG_LEVEL=info
VDB_ENABLE_METRICS=true
VDB_HEARTBEAT_INTERVAL=30
