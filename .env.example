# -------------------------
# OpenClaw Pi – Bot Settings
# -------------------------

# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here
ALLOWED_USER=your_telegram_user_id_here

# GitHub (Repo B only, fine-grained)
GITHUB_TOKEN=your_github_pat_here
SANDBOX_REPO=your_github_username/repo-b

# -------------------------
# Redis Job Queue
# -------------------------
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:your_redis_password_here@bot-redis:6379/0

# -------------------------
# Bot Version
# -------------------------
BOT_VERSION=1.0.0

# -------------------------
# LLM Container
# -------------------------
# Name of Docker volume where Qwen2-1.5B model is stored
LLM_VOLUME=openclaw_llm_model

# Internal endpoint for Bot → LLM communication
LLM_ENDPOINT=http://openclaw-llm:8080

# -------------------------
# Optional Debug / Logging
# -------------------------
LOG_LEVEL=info
